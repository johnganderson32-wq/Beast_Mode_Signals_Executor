# Beast Mode Signals Executor — environment config
# Copy this file to .env and fill in your values

PORT=3100
WEBHOOK_SECRET=

# Ngrok URL — used for health check dot on dashboard
# Set to your reserved ngrok domain (or leave blank to skip check)
NGROK_URL=https://your-domain.ngrok-free.app

# ProjectX credentials
PROJECTX_API_URL=https://gateway-rtc.main.topstepx.com/api
PROJECTX_USERNAME=your_username
PROJECTX_API_KEY=your_api_key

# Account
PROJECTX_ACCOUNT_ID=your_account_id

# Contract IDs — pick MINI or MICRO for each product.
# The executor normalizes any TV ticker (NQ1!, MNQ1!, ENQ1!, etc.)
# to the product family, then uses the contract ID below.
# Only set the one you want to trade — mini OR micro, not both.
#
# NQ family (Nasdaq):
#   Mini  (ENQ):  CON.F.US.ENQ.M26     ← $5/pt per contract
#   Micro (MNQ):  CON.F.US.MNQ.M26     ← $0.50/pt per contract
NQ_CONTRACT_ID=CON.F.US.MNQ.M26
#
# GC family (Gold):
#   Full  (GC):   not available on ProjectX prop accounts
#   Micro (MGC):  CON.F.US.MGC.M26     ← $1/pt per contract
GC_CONTRACT_ID=CON.F.US.MGC.M26

# Contracts per trade
# 1 = all contracts exit at TP1 (0.5R)
# 2 = 1 contract exits at TP1, 1 runner held to target (1R)
# 3+ = (qty-1) at TP1, 1 runner at target
NQ_CONTRACTS=2
GC_CONTRACTS=1
