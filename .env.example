# Beast Mode Signals Executor — environment config
# Copy this file to .env and fill in your values.
# All risk limits are in DOLLARS. Points/ticks are only used inside order math.

PORT=3100
WEBHOOK_SECRET=

# Ngrok URL — used for the health-check dot on the dashboard
# Set to your reserved ngrok domain (or leave blank to skip check)
NGROK_URL=https://your-domain.ngrok-free.app

# ── ProjectX credentials ────────────────────────────────────────────────────
PROJECTX_API_URL=https://api.topstepx.com/api
PROJECTX_USERNAME=your_username
PROJECTX_API_KEY=your_api_key
PROJECTX_ACCOUNT_ID=your_account_id

# ── Active contracts per family ─────────────────────────────────────────────
# Pick ONE mini OR micro per family — the one you want to trade today.
# Contract specs (tick size / tick value → $/pt):
#   ENQ: 0.25 / $5.00   → $20/pt
#   MNQ: 0.25 / $0.50   →  $2/pt
#   GC : 0.10 / $10.00  → $100/pt
#   MGC: 0.10 / $1.00   → $10/pt
#   ES : 0.25 / $12.50  → $50/pt
#   MES: 0.25 / $1.25   →  $5/pt
NQ_CONTRACT_ID=CON.F.US.MNQ.M26
GC_CONTRACT_ID=CON.F.US.MGC.M26
ES_CONTRACT_ID=

# ── Fixed contract quantities per PRODUCT CODE ──────────────────────────────
# Used when Dynamic Sizing is OFF. Match the code of your active contract.
# 1 = all contracts exit at TP1 (0.5R)
# 2 = 1 contract exits at TP1, 1 runner held to target (1R)
# 3+ = (qty-1) at TP1, 1 runner at target
NQ_CONTRACTS=2
MNQ_CONTRACTS=2
GC_CONTRACTS=0
MGC_CONTRACTS=1
ES_CONTRACTS=0
MES_CONTRACTS=0

# ── Risk gates (dollars, 0 = disabled) ──────────────────────────────────────
# Hitting a daily cap flips the trading toggle OFF for the rest of the session.
DAILY_LOSS_CAP_USD=0
DAILY_PROFIT_CAP_USD=0

# Per-trade loss cap — applied when DYNAMIC_SIZING_ENABLED=true.
# qty = floor(PER_TRADE_LOSS_CAP_USD / (SL pts × $/pt))
# If risk isn't enough to fit one contract, the signal is blocked.
DYNAMIC_SIZING_ENABLED=false
PER_TRADE_LOSS_CAP_USD=0

# Session close (HH:MM ET) — hard stop. No new entries until 18:00 ET reopen.
# Leave blank to disable.
SESSION_CLOSE_TIME=

# Consecutive loss circuit breaker
CONSECUTIVE_LOSS_LIMIT=0
CONSECUTIVE_LOSS_PAUSE_MINS=0

# ── Broker commissions (round-turn per contract, USD) ──────────────────────
# Subtracted from pnlDollars at trade close so session P&L and reported stats
# match the broker account. Micro rates ($1.24 MNQ / $1.74 MGC) come from the
# standard Topstep schedule and match EvilSignals. Mini rates vary by account
# group — verify against your own schedule before trading minis. 0 = no deduction.
COMMISSION_MNQ=1.24
COMMISSION_MGC=1.74
COMMISSION_MES=1.24
COMMISSION_ENQ=0
COMMISSION_GC=0
COMMISSION_ES=0

# ── ATM (future) ────────────────────────────────────────────────────────────
# standard = TP1 + runner (current)
# momentum = trailing SL driven by RTC quote feed (not yet wired — needs monitor.js)
ATM_STRATEGY=standard
